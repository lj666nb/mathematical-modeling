# ============================================================
# AI 数学建模智能教学平台 — 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ============================================================

# === JWT 认证 (必填) ===
# ⚠️ 生产环境必须设置为随机强密钥！
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-random-secret-key-change-me

# === 数据加密 (必填) ===
# ⚠️ 用于加密数据库中存储的API密钥等敏感字段
# 开发环境会自动生成并持久化到 data/.encryption_key
# 生产环境必须设置此变量！
# 生成方法: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# DATA_ENCRYPTION_KEY=your-fernet-key-here

# === 数据库 ===
# 开发环境默认使用 SQLite
# DATABASE_URL=sqlite+aiosqlite:///./data/tutoring.db
# 生产环境切换为 PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tutoring

# === Redis (可选，不可用则自动降级到内存) ===
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=

# === 应用配置 ===
# APP_NAME=AI-Tutoring Platform
# APP_VERSION=1.0.0
# DEBUG=True
