# ============================================================
# AI 数学建模智能教学平台 — Docker Compose 环境变量
# 复制此文件为 .env 并填写实际值
# 用法: cp .env.example .env  →  编辑 .env  →  docker compose up -d --build
# ============================================================

# === 前端端口（可选，默认 80）===
# FRONTEND_PORT=80

# === JWT 认证密钥（生产环境必填！）===
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=dev-secret-change-in-production

# === 数据加密密钥（生产环境必填！）===
# 用于加密数据库中存储的 LLM API 密钥等敏感字段
# 开发环境留空则自动生成并持久化到 data/.encryption_key
# 生成方法: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# DATA_ENCRYPTION_KEY=
